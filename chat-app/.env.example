# Sui Network
VITE_SUI_NETWORK=testnet
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
VITE_SUI_GRAPHQL_URL=https://sui-testnet.mystenlabs.com/graphql

# Package IDs (only needed for localnet/devnet; auto-detected for testnet/mainnet)
# VITE_PERMISSIONED_GROUPS_ORIGINAL_PACKAGE_ID=0x...
# VITE_PERMISSIONED_GROUPS_LATEST_PACKAGE_ID=0x...
# VITE_MESSAGING_GROUPS_ORIGINAL_PACKAGE_ID=0x...
# VITE_MESSAGING_GROUPS_LATEST_PACKAGE_ID=0x...
# VITE_MESSAGING_GROUPS_NAMESPACE_ID=0x...
# VITE_MESSAGING_GROUPS_VERSION_ID=0x...

# Relayer
VITE_RELAYER_URL=http://localhost:3000

# Walrus (testnet defaults)
VITE_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
VITE_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
VITE_WALRUS_EPOCHS=5

# Seal Key Servers (threshold encryption)
# VITE_SEAL_KEY_SERVER_OBJECT_IDS=0x...,0x...
